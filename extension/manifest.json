{
  "manifest_version": 3,
  "name": "SocialFeed Bookmarks Exporter",
  "version": "1.1",
  "description": "Scrapes and exports saved bookmarks from Instagram and X with embedded Base64 thumbnails, using automated scroll scanning.",
  "permissions": [
    "activeTab",
    "scripting",
    "downloads",
    "storage"
  ],
  "host_permissions": [
    "*://*.instagram.com/*",
    "*://*.x.com/*",
    "*://*.twitter.com/*",
    "*://*.cdninstagram.com/*",
    "*://*.fbcdn.net/*",
    "*://*.twimg.com/*",
    "*://*.pbs.twimg.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.instagram.com/*",
        "*://*.x.com/*",
        "*://*.twitter.com/*"
      ],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "SocialFeed Exporter"
  }
}
